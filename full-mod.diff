diff --git a/src/utils/ghost.ts b/src/utils/ghost.ts
new file mode 100644
index 0000000..425f132
--- /dev/null
+++ b/src/utils/ghost.ts
@@ -0,0 +1,66 @@
+export interface GhostFrame {
+  t: number // temps écoulé depuis le début du run (ms)
+  x: number
+  y: number
+}
+
+export interface GhostRun {
+  frames: GhostFrame[]
+}
+
+const GHOST_KEY_PREFIX = 'ghostRun_'
+
+/**
+ * Récupère le run fantôme (meilleur temps) sauvegardé pour un niveau donné.
+ * Retourne null si aucun run n'est enregistré ou si les données sont corrompues.
+ */
+export function getGhostRun(level: number): GhostRun | null {
+  const raw = localStorage.getItem(GHOST_KEY_PREFIX + level)
+  if (!raw) return null
+
+  try {
+    const parsed = JSON.parse(raw) as GhostRun
+    if (!parsed?.frames?.length) return null
+    return parsed
+  } catch {
+    return null
+  }
+}
+
+/**
+ * Sauvegarde le run fantôme pour un niveau donné (écrase l'ancien).
+ */
+export function saveGhostRun(level: number, run: GhostRun) {
+  localStorage.setItem(GHOST_KEY_PREFIX + level, JSON.stringify(run))
+}
+
+/**
+ * Exporte le run fantôme d'un niveau sous forme de chaîne JSON, prête à être
+ * partagée (fichier, copier-coller...). Inclut le niveau pour faciliter l'import.
+ */
+export function exportGhostRun(level: number): string | null {
+  const run = getGhostRun(level)
+  if (!run) return null
+  return JSON.stringify({ level, ...run })
+}
+
+/**
+ * Importe un run fantôme depuis une chaîne JSON (exportée via exportGhostRun).
+ * Si le niveau cible est fourni, il est utilisé à la place de celui contenu dans le JSON
+ * (utile si on veut appliquer un fantôme partagé à un autre niveau).
+ * Retourne le niveau sur lequel le fantôme a été importé, ou null en cas d'échec.
+ */
+export function importGhostRun(json: string, targetLevel?: number): number | null {
+  try {
+    const parsed = JSON.parse(json) as GhostRun & { level?: number }
+    if (!parsed?.frames?.length) return null
+
+    const level = targetLevel ?? parsed.level
+    if (!level) return null
+
+    saveGhostRun(level, { frames: parsed.frames })
+    return level
+  } catch {
+    return null
+  }
+}
